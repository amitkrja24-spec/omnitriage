rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tasks: anyone can create (field workers), 
    // reads are open for MVP dashboard (no auth yet)
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Volunteers: open read/write for MVP
    match /volunteers/{volunteerId} {
      allow read: if true;
      allow write: if true;
    }

    // Volunteer sessions: read/write by anyone (bot uses Admin SDK anyway)
    match /volunteer_sessions/{sessionId} {
      allow read, write: if true;
    }

    // NGOs: read-only for dashboard
    match /ngos/{ngoId} {
      allow read: if true;
      allow write: if false;
    }

    // Audit log: write only by Cloud Functions (Admin SDK bypasses rules)
    // Read open for coordinator dashboard
    match /audit_log/{logId} {
      allow read: if true;
      allow write: if false;
    }
  }
}